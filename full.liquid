<div class="screen">
  <div class="view view--full">
    <div class="layout" style="padding:0;height:calc(100% - 32px);">
      <div id="tfl-board" style="display:flex;flex-direction:column;width:100%;height:100%;"></div>
    </div>
    <div class="title_bar">
      <img class="image" src="https://upload.wikimedia.org/wikipedia/commons/4/41/Underground.svg" />
      <span class="title">TfL Line Status</span>
      <span class="instance" id="updated-time"></span>
    </div>
  </div>
</div>

<script>
  const LINE_META = {
    "bakerloo":           "Bakerloo",
    "central":            "Central",
    "circle":             "Circle",
    "district":           "District",
    "hammersmith-city":   "H & City",
    "jubilee":            "Jubilee",
    "metropolitan":       "Metropolitan",
    "northern":           "Northern",
    "piccadilly":         "Piccadilly",
    "victoria":           "Victoria",
    "waterloo-city":      "Waterloo & City",
    "elizabeth":          "Elizabeth",
    "lioness":            "Lioness",
    "mildmay":            "Mildmay",
    "windrush":           "Windrush",
    "weaver":             "Weaver",
    "suffragette":        "Suffragette",
    "liberty":            "Liberty",
  };

  const LINE_ORDER = [
    "bakerloo","central","circle","district","elizabeth",
    "hammersmith-city","jubilee","metropolitan","northern",
    "piccadilly","victoria","waterloo-city",
    "lioness","mildmay","windrush","weaver","suffragette","liberty"
  ];

  const boxStyle = [
    "flex:1",
    "width:0",
    "display:flex",
    "align-items:center",
    "justify-content:center",
    "padding:2px 6px",
    "font-size:9.5px",
    "font-weight:700",
    "text-transform:uppercase",
    "letter-spacing:0.06em",
    "line-height:1.25",
    "text-align:center",
    "color:#111",
    "background:#fff",
    "border:1.5px solid #111",
  ].join(";");

  const statusStyle = [
    "flex:1",
    "width:0",
    "display:flex",
    "align-items:center",
    "justify-content:center",
    "padding:2px 6px",
    "font-size:9.5px",
    "font-weight:400",
    "line-height:1.25",
    "text-align:center",
    "color:#111",
    "background:#fff",
    "border:1.5px solid #111",
    "border-left:none",
  ].join(";");

  const statusDisruptedStyle = [
    "flex:1",
    "width:0",
    "display:flex",
    "align-items:center",
    "justify-content:center",
    "padding:2px 6px",
    "font-size:9.5px",
    "font-weight:700",
    "line-height:1.25",
    "text-align:center",
    "color:#fff",
    "background:#111",
    "border:1.5px solid #111",
    "border-left:none",
  ].join(";");

  function parseLines(data) {
    const results = {};
    for (const line of data) {
      const statuses = line.lineStatuses || [];
      const worst = statuses.reduce((best, s) =>
        s.statusSeverity < best.statusSeverity ? s : best,
        statuses[0] || { statusSeverity: 10, statusSeverityDescription: "Good Service" }
      );
      results[line.id] = {
        isGood: worst.statusSeverity >= 10,
        shortStatus: worst.statusSeverityDescription || "Good Service"
      };
    }
    return results;
  }

  function render(data) {
    const parsed = parseLines(data);
    const board  = document.getElementById("tfl-board");
    board.innerHTML = "";

    const ids = [
      ...LINE_ORDER.filter(id => parsed[id]),
      ...Object.keys(parsed).filter(id => !LINE_ORDER.includes(id))
    ];

    for (const id of ids) {
      const label  = LINE_META[id] || id;
      const status = parsed[id] || { isGood: true, shortStatus: "Good Service" };

      const row = document.createElement("div");
      row.style.cssText = "display:flex;align-items:center;justify-content:center;flex:1;";

      const pair = document.createElement("div");
      pair.style.cssText = "display:flex;align-items:stretch;height:100%;width:320px;";

      const pill = document.createElement("div");
      pill.style.cssText = boxStyle;
      pill.textContent = label;

      const box = document.createElement("div");
      box.style.cssText = status.isGood ? statusStyle : statusDisruptedStyle;
      box.textContent = status.shortStatus;

      pair.appendChild(pill);
      pair.appendChild(box);
      row.appendChild(pair);
      board.appendChild(row);
    }

    const now     = new Date();
    const timeStr = now.toLocaleTimeString("en-GB", { hour: "2-digit", minute: "2-digit" });
    const dateStr = now.toLocaleDateString("en-GB",  { day: "numeric", month: "short" });
    document.getElementById("updated-time").textContent = `${dateStr}, ${timeStr}`;
  }

  // Replace TFL_DATA with {{ tfl_json }} in the TRMNL editor
  const TFL_DATA = [
    {"id":"bakerloo",         "lineStatuses":[{"statusSeverity":9, "statusSeverityDescription":"Minor Delays"}]},
    {"id":"central",          "lineStatuses":[{"statusSeverity":6, "statusSeverityDescription":"Severe Delays"}]},
    {"id":"circle",           "lineStatuses":[{"statusSeverity":10,"statusSeverityDescription":"Good Service"}]},
    {"id":"district",         "lineStatuses":[{"statusSeverity":10,"statusSeverityDescription":"Good Service"}]},
    {"id":"hammersmith-city", "lineStatuses":[{"statusSeverity":10,"statusSeverityDescription":"Good Service"}]},
    {"id":"jubilee",          "lineStatuses":[{"statusSeverity":10,"statusSeverityDescription":"Good Service"}]},
    {"id":"metropolitan",     "lineStatuses":[{"statusSeverity":10,"statusSeverityDescription":"Good Service"}]},
    {"id":"northern",         "lineStatuses":[{"statusSeverity":10,"statusSeverityDescription":"Good Service"}]},
    {"id":"piccadilly",       "lineStatuses":[{"statusSeverity":10,"statusSeverityDescription":"Good Service"}]},
    {"id":"victoria",         "lineStatuses":[{"statusSeverity":10,"statusSeverityDescription":"Good Service"}]},
    {"id":"waterloo-city",    "lineStatuses":[{"statusSeverity":10,"statusSeverityDescription":"Good Service"}]},
    {"id":"elizabeth",        "lineStatuses":[{"statusSeverity":6, "statusSeverityDescription":"Severe Delays"}]},
    {"id":"lioness",          "lineStatuses":[{"statusSeverity":10,"statusSeverityDescription":"Good Service"}]},
    {"id":"mildmay",          "lineStatuses":[{"statusSeverity":10,"statusSeverityDescription":"Good Service"}]},
    {"id":"windrush",         "lineStatuses":[{"statusSeverity":10,"statusSeverityDescription":"Good Service"}]},
    {"id":"weaver",           "lineStatuses":[{"statusSeverity":10,"statusSeverityDescription":"Good Service"}]},
    {"id":"suffragette",      "lineStatuses":[{"statusSeverity":10,"statusSeverityDescription":"Good Service"}]},
    {"id":"liberty",          "lineStatuses":[{"statusSeverity":10,"statusSeverityDescription":"Good Service"}]}
  ];

  render(TFL_DATA);
</script>
