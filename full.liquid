<style>
body {
  margin: 0; /* Ensure no default body margin interferes */
}
.screen {
  /* Add padding-bottom here based on status-bar height */
  padding-bottom: 50px; /* Estimate, adjust if necessary */
}
.status-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  background-color: #f0f0f0;
  padding: 5px 10px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-sizing: border-box; /* Include padding and border in the element's total width and height */
}
.status-bar .image {
  /* Specific styles for the image if needed */
}
.status-bar .update-time {
  /* Specific styles for the text if needed */
  font-size: 12px;
}
</style>
<div class="screen">
  <div class="view view--full">
    <div class="layout">
      <div class="columns">
        <div class="column">
          <div class="markdown">
            {% for line in data %}
            <div class="row" style="display: flex; justify-content: space-between; padding: 2px 0; font-size: 14px;">
              <div class="line-name" style="text-align: right; flex: 1; padding-right: 10px;">
                {{ line.name }}
              </div>
              <div class="line-status" style="text-align: left; flex: 1;">
                {% if line.lineStatuses[0].statusSeverityDescription == "Good Service" %}
                {{ line.lineStatuses[0].statusSeverityDescription }}
                {% else %}
                <span style="background-color: black; color: white; padding: 2px 0px; display: inline-block;">
                  {{ line.lineStatuses[0].statusSeverityDescription }}
                </span>
                {% endif %}
              </div>
            </div>
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="status-bar">
    <img class="image" src="https://upload.wikimedia.org/wikipedia/commons/4/41/Underground.svg" width="30" />
    <span class="update-time">Last updated: [time]</span>
  </div>
</div>
