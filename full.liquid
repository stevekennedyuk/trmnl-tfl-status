<div class="container">
  <div class="title-bar">
    <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/5/54/Transport_for_London_logo_%282013%29.svg/2560px-Transport_for_London_logo_%282013%29.svg.png" alt="TfL Logo" class="logo">
    <h1>Tube Status</h1>
  </div>
  <div id="status-container"></div>
</div>

<style>
  .container {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    background-color: #000;
    color: #fff;
    font-family: sans-serif;
  }

  .title-bar {
    display: flex;
    align-items: center;
    padding: 10px;
    background-color: #111;
  }

  .logo {
    height: 30px;
    margin-right: 10px;
  }

  h1 {
    font-size: 1.5em;
    margin: 0;
  }

  #status-container {
    flex-grow: 1;
    overflow-y: auto;
    padding: 10px;
  }

  .line-status {
    display: flex;
    justify-content: space-between;
    margin-bottom: 5px;
  }

  .line-name {
    text-align: right;
    flex-basis: 50%;
    padding-right: 10px;
  }

  .status {
    text-align: left;
    flex-basis: 50%;
  }

  .status.disrupted {
    background-color: #fff;
    color: #000;
  }
</style>

<script>
  (function() {
    const statusContainer = document.getElementById('status-container');
    const pollingUrl = '{{ Polling-URL }}';

    function fetchData() {
      fetch(pollingUrl)
        .then(response => response.json())
        .then(data => {
          statusContainer.innerHTML = '';
          data.forEach(line => {
            const lineStatus = document.createElement('div');
            lineStatus.classList.add('line-status');

            const lineName = document.createElement('div');
            lineName.classList.add('line-name');
            lineName.textContent = line.name;

            const status = document.createElement('div');
            status.classList.add('status');
            const statusText = line.lineStatuses[0].statusSeverityDescription;
            status.textContent = statusText;

            if (statusText !== 'Good Service') {
              status.classList.add('disrupted');
            }

            lineStatus.appendChild(lineName);
            lineStatus.appendChild(status);
            statusContainer.appendChild(lineStatus);
          });
        })
        .catch(error => {
          console.error('Error fetching TfL data:', error);
          statusContainer.innerHTML = '<p>Error loading tube status. Please try again later.</p>';
        });
    }

    fetchData();
    setInterval(fetchData, 60000); // Refresh every 60 seconds
  })();
</script>